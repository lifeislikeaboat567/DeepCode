# LLM 配置 (必需)
DEEPCODE_LLM_PROVIDER=
DEEPCODE_LLM_MODEL=
DEEPCODE_LLM_API_KEY=
DEEPCODE_LLM_BASE_URL=

# API 服务配置
DEEPCODE_API_HOST=0.0.0.0
DEEPCODE_API_PORT=8000
DEEPCODE_DEBUG=false

# 数据存储
DEEPCODE_DATA_DIR=~/.deepcode
DEEPCODE_DB_URL=sqlite+aiosqlite:///~/.deepcode/deepcode.db

# 平台桥接
DEEPCODE_CHAT_BRIDGE_ENABLED=true
DEEPCODE_CHAT_BRIDGE_ALLOWED_PLATFORMS=generic,qq,wechat,feishu
DEEPCODE_CHAT_BRIDGE_DEFAULT_MODE=ask
DEEPCODE_CHAT_BRIDGE_VERIFY_TOKEN=
DEEPCODE_CHAT_BRIDGE_CALLBACK_DELIVERY_ENABLED=false

# QQ / NapCat
DEEPCODE_CHAT_BRIDGE_QQ_DELIVERY_MODE=auto
DEEPCODE_CHAT_BRIDGE_QQ_SIGNING_SECRET=
DEEPCODE_CHAT_BRIDGE_QQ_NAPCAT_API_BASE_URL=http://127.0.0.1:3000
DEEPCODE_CHAT_BRIDGE_QQ_NAPCAT_ACCESS_TOKEN=
DEEPCODE_CHAT_BRIDGE_QQ_NAPCAT_WEBHOOK_TOKEN=

# 搜索工具 (可选)
DEEPCODE_SEARCH_API_KEY=

# 安全配置
DEEPCODE_MAX_EXECUTION_TIME=30
DEEPCODE_ALLOWED_SHELLS=ls,cat,grep,find,python3,pip,echo,pwd,head,tail,wc

# 记忆配置
DEEPCODE_MAX_HISTORY_MESSAGES=50
DEEPCODE_VECTOR_COLLECTION=deepcode
